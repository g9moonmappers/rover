# EKF prosess

def ekf_predict(x, P, V, w, dt):
    teta = x[2]

    # ulinær modell
    x_pred = np.array([
        x[0] + V * math.cos(teta) * dt,
        x[1] + V * math.sin(teta) * dt,
        x[2] + w * dt
    ])

    # tar i bruk jacobian av systemet
    F = np.array([
        [1.0, 0.0, -V * math.sin(teta) * dt],
        [0.0, 1.0, V * math.cos(teta) * dt],
        [0.0, 0.0, 1.0]
    ])

    P_pred = F @ P @ F.T + Q

    return x_pred, P_pred


def ekf_update(x_pred, P_pred, obs):
    S = H @ P_pred @ H.T + R
    K_gain = P_pred @ H.T @ np.linalg.inv(S)

    innovation = obs - H @ x_pred
    innovation[2] = noramilise_angle(innovation[2])

    x_upd = x_pred + K_gain @ innovation
    P_upd = (np.eye(Nstate) - K_gain @ H) @ P_pred

    return x_upd, P_upd

# andre funksjoner


def noramilise_angle(a):
    # normalisereer vinkelen slik at den holder seg
    return (a + math.pi) % (2 * math.pi) - math.pi


def til_vinkelhastighet(wl_o, wr_o):
    V = (r/2) * (wr_o + wl_o)
    w = (r / B) * (wr_o - wl_o)

    return V, w


def h_til_vinkelh(V, w):
    wl = (V/r) - (w * B / (2*r))
    wr = (V/r) + (w * B / (2*r))

    return wr, wl


